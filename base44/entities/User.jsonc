{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "broker",
        "backoffice",
        "customer"
      ],
      "default": "broker"
    },
    "phone": {
      "type": "string",
      "description": "Telefonnummer"
    },
    "avatar_url": {
      "type": "string",
      "description": "Profilbild URL"
    }
  }
}