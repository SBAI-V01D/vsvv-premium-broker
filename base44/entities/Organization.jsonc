{
  "name": "Organization",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Organisationsname"
    },
    "type": {
      "type": "string",
      "enum": [
        "strukturvertrieb",
        "broker",
        "partner",
        "sonstiges"
      ],
      "default": "broker",
      "description": "Organisationstyp"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ],
      "default": "active",
      "description": "Status"
    },
    "finma_number": {
      "type": "string",
      "description": "FINMA-Registrierungsnummer der Organisation"
    },
    "street": {
      "type": "string",
      "description": "Strasse"
    },
    "zip_code": {
      "type": "string",
      "description": "Postleitzahl"
    },
    "city": {
      "type": "string",
      "description": "Stadt"
    },
    "phone": {
      "type": "string",
      "description": "Telefon"
    },
    "email": {
      "type": "string",
      "description": "E-Mail"
    },
    "website": {
      "type": "string",
      "description": "Website"
    },
    "notes": {
      "type": "string",
      "description": "Notizen"
    }
  },
  "required": [
    "name"
  ]
}